# =========================
# CONFIGURAÇÕES DO BOT (OBRIGATÓRIO)
# =========================

# Token do bot Discord (obtido em https://discord.com/developers/applications)
DISCORD_TOKEN=

# ID da aplicação do bot (Client ID na página do Developer Portal)
CLIENT_ID=

# ID do servidor Discord onde os comandos serão registrados
GUILD_ID=

# =========================
# BANCO DE DADOS (OBRIGATÓRIO)
# =========================

# URI de conexão com o MongoDB
MONGO_URI=

# =========================
# CANAIS (OPCIONAL - O BOT AUTO-DESCOBRE E CRIA SE ESTIVER VAZIO)
# =========================

# Categoria onde os canais de tickets serão criados
CATEGORY_TICKETS=

# Categoria para onde denúncias encaminhadas à corregedoria serão movidas
CATEGORY_CORREGEDORIA=

# Canal de logs administrativos/tickets arquivados
CHANNEL_ADMIN_LOGS=

# Canal de avaliação das candidaturas (Edital)
CHANNEL_AVALIACAO=

# Canal de resultados das candidaturas (Edital)
CHANNEL_RESULTADOS=

# Canal onde o painel de ponto será enviado
CHANNEL_PONTO_PANEL=

# Canal de logs de ponto
CHANNEL_PONTO_LOGS=

# Canal de logs de entrada/saida de membros
CHANNEL_MEMBER_LOGS=

# Canal onde os casos de corregedoria/advertência serão votados
CHANNEL_DISCIPLINARY_WARNINGS=

# Canal onde o painel de ausência será enviado
CHANNEL_AUSENCIA_PANEL=

# Canal de logs/avaliação de ausências
CHANNEL_AUSENCIA_LOGS=

# =========================
# CARGOS (OPCIONAL - O BOT AUTO-DESCOBRE E CRIA SE ESTIVER VAZIO)
# =========================

# Cargo do comando/administração da LSPD
ROLE_COMMAND=

# Cargo da equipe que pode visualizar e gerenciar tickets (Staff)
ROLE_TICKET_STAFF=

# Cargo atribuído ao candidato aprovado no edital (Recruta)
ROLE_RECRUTA=

# Cargos de advertência aplicados pela corregedoria
ROLE_ADV_VERBAL=
ROLE_ADV_1=
ROLE_ADV_2=
ROLE_ADV_3=

# Prazo padrão, em dias, para cada advertência
ADV_VERBAL_DAYS=1
ADV_1_DAYS=7
ADV_2_DAYS=14
ADV_3_DAYS=30

# =========================
# IA DOS TICKETS (OPCIONAL)
# =========================

# Chave do Gemini para a IA responder nos tickets
GEMINI_API_KEY=

# Modelo usado pela IA dos tickets
GEMINI_MODEL=gemini-3.5-flash

# Defina false para desligar a IA sem remover a chave
TICKET_AI_ENABLED=true

# Quantidade de mensagens recentes usadas como contexto
TICKET_AI_MAX_HISTORY=12

# Intervalo minimo entre respostas automaticas da IA por ticket
TICKET_AI_COOLDOWN_MS=5000

# Defina false para impedir o relatorio automatico quando a triagem estiver completa
TICKET_AI_REPORT_ENABLED=true

# =========================
# API BATE-PONTO (INTEGRAÇÃO JOGO)
# =========================
# Porta onde o servidor HTTP de Bate-Ponto escutará
PONTO_API_PORT=3000
# Token seguro para autorizar requisições do FiveM
PONTO_API_KEY=TROCAR_POR_TOKEN_SEGURO_DO_BATE_PONTO
# Host/Endereço de rede (use 127.0.0.1 para acesso somente local)
PONTO_API_HOST=127.0.0.1

